# agents/.env.example - Copy to agents/.env and fill in your real keys

# xAI (Grok) API Key - Get from https://console.x.ai/
XAI_API_KEY=

# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) API Key - Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: model selection (uncomment and change if you want specific models)
# XAI_MODEL=grok-beta
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
